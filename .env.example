# ─────────────────────────────────────────────────────────────────────────
# IMKON Doors — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. NEVER commit real secrets.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser — keep
# every secret WITHOUT that prefix.
# ─────────────────────────────────────────────────────────────────────────

# --- Telegram (from @BotFather) ---
# Server-only. Used to validate initData signatures and run the bot.
TELEGRAM_BOT_TOKEN=

# Public HTTPS URL where the Mini App is served. The bot's /start launch
# button opens this. Locally this is your tunnel URL (cloudflared/ngrok),
# e.g. https://abcd-1234.trycloudflare.com . In production, your Vercel URL.
MINI_APP_URL=

# The bot's @username WITHOUT the @ (used by the admin Telegram Login Widget).
# Safe in the browser.
NEXT_PUBLIC_BOT_USERNAME=

# Admin allowlist (spec §11): comma-separated Telegram IDs of the ~3 admins.
ADMIN_TELEGRAM_IDS=

# Optional: secret used to sign admin session cookies. Falls back to the bot
# token if unset. Set a long random string in production.
ADMIN_SESSION_SECRET=

# --- Supabase (Project Settings → API) ---
# Project URL + anon (public) key are safe in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key bypasses Row Level Security. SERVER-ONLY. Never expose.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Added in later phases (left here for reference, not needed for Phase 0):
# ESKIZ_EMAIL=
# ESKIZ_PASSWORD=
# ESKIZ_SENDER=
# CLICK_SERVICE_ID=
# CLICK_MERCHANT_ID=
# CLICK_SECRET_KEY=
# CLICK_MERCHANT_USER_ID=
# ADMIN_TELEGRAM_IDS=        # comma-separated allowlist of 3 admin IDs
# ─────────────────────────────────────────────────────────────────────────
